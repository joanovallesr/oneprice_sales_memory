# VCON MCP Server (STDIO – Docker/local)
# Replace with your TADHack Docker command. Example:
#   VCON_MCP_COMMAND=docker
#   VCON_MCP_STDIO_ARGS=run,--rm,-i,vcon/vcon-mcp
# Or for npx: VCON_MCP_COMMAND=npx, VCON_MCP_STDIO_ARGS=--yes,@vcon-dev/vcon-mcp
VCON_MCP_COMMAND=docker
VCON_MCP_URL=http://localhost:3000
VCON_MCP_STDIO_ARGS=run,--rm,-i,vcon/vcon-mcp-server:latest

# OpenAI (required for analyze_and_tag_vcon and generate_followup)
OPENAI_API_KEY=sk-your-key-here

# Optional: salesperson name used in vCon parties
SALESPERSON_NAME=JoanOvalles
